{
  "name": "x-reporter",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "description": "Per-user X likes/bookmarks digest service (Bun + NestJS)",
  "scripts": {
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist",
    "test": "bun test",
    "lint": "bunx biome lint .",
    "format": "bunx biome format --write .",
    "typecheck": "bunx tsc --noEmit",
    "setup:appwrite": "bun run scripts/setup-appwrite.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.5.0",
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "bullmq": "^5.73.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "4.6.1",
    "node-appwrite": "23.1.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nestjs/testing": "11.1.18",
    "@types/bun": "1.3.11",
    "pino-pretty": "13.1.3",
    "typescript": "6.0.2"
  }
}
